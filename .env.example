# ═══════════════════════════════════════════════════════════════
#  UltraBot v3 — Environment Variables
#  Copy to .env and fill in your values
# ═══════════════════════════════════════════════════════════════

# ── Required ──────────────────────────────────────────────────
BINGX_API_KEY=YOUR_BINGX_API_KEY
BINGX_SECRET_KEY=YOUR_BINGX_SECRET_KEY
TELEGRAM_TOKEN=YOUR_TELEGRAM_BOT_TOKEN
TELEGRAM_CHAT_ID=YOUR_TELEGRAM_CHAT_ID

# ── Strategy (tune after backtesting) ─────────────────────────
TIMEFRAME=15m
CONFIRM_TF=1h
TREND_TF=4h
PERIOD=25
ADX_LEN=14
DI_LEN=14
ADX_THRESH=28
RSI_LEN=14
RSI_OB=72
RSI_OS=28
VOL_SPIKE_MULT=1.8
MIN_CONFIDENCE=55

# ── Universe ──────────────────────────────────────────────────
MIN_VOLUME_USDT=3000000
TOP_N_SYMBOLS=60
BLACKLIST=                  # Comma-separated, e.g. LUNA-USDT,FTT-USDT

# ── Risk ─────────────────────────────────────────────────────
LEVERAGE=5
RISK_PCT=1.0
MAX_OPEN_TRADES=5
SL_PCT=2.0
TP_PCT=4.0
TRAILING_SL=true
MAX_DRAWDOWN_PCT=8.0
DAILY_LOSS_LIMIT=4.0
MAX_CONSECUTIVE_LOSSES=5
COOLDOWN_AFTER_LOSS=300

# ── Performance ───────────────────────────────────────────────
SCAN_INTERVAL=8
MAX_CONCURRENT=30
HTTP_TIMEOUT=6

# ── Dashboard ─────────────────────────────────────────────────
DASHBOARD_ENABLED=true
DASHBOARD_PORT=8080
