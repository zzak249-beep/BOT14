# ─── OBLIGATORIO ───────────────────────────────
BINGX_API_KEY=tu_api_key_aqui
BINGX_API_SECRET=tu_api_secret_aqui
TELEGRAM_TOKEN=tu_bot_token_aqui
TELEGRAM_CHAT_ID=tu_chat_id_aqui

# ─── SÍMBOLO ───────────────────────────────────
SYMBOL=ETH-USDT

# ─── RIESGO Y TAMAÑO ───────────────────────────
RISK_PCT=0.02          # 2% del balance por trade
MAX_POS_USDT=20        # máximo $20 USDT por posición
MIN_POS_USDT=5         # mínimo $5 USDT por posición
MAX_LEV=10             # apalancamiento

# ─── ESTRATEGIA ────────────────────────────────
MIN_DIV=0.25           # fuerza mínima de divergencia (0-1)
ATR_STOP=1.5           # SL inicial = 1.5×ATR desde extremo
TRAIL_ATR=2.0          # trailing stop = 2×ATR desde máximo
TRAIL_PCT=0.05         # trailing stop = 5% desde máximo
MIN_PROFIT_TRAIL=0.01  # activar trailing solo si ganas >1%
INITIAL_ADD=0.3        # add inicial = 30% del tamaño original

# ─── FILTROS ───────────────────────────────────
BUY_FILTER=true        # activar filtros de compra
RSI_THRESH=40          # RSI < 40 para compra
VOL_RATIO=0.8          # volumen > 0.8x media para compra
CLEAR_30M=true         # cerrar también con TD9 30min

# ─── TIMING ────────────────────────────────────
CHECK_SEC=60           # chequear cada 60 segundos
KLINES_LIMIT=500       # barras históricas a descargar
MIN_BARS=1             # barras de protección tras entrada
