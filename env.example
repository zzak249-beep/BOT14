# ═══════════════════════════════════════════════════
#  PHANTOM EDGE BOT — Variables de entorno
#  NUNCA subas este archivo real (.env) a GitHub
# ═══════════════════════════════════════════════════

# ── BingX API ────────────────────────────────────
BINGX_API_KEY=tu_api_key_aqui
BINGX_API_SECRET=tu_api_secret_aqui

# ── Telegram ─────────────────────────────────────
TELEGRAM_BOT_TOKEN=123456789:ABCdef...
TELEGRAM_CHAT_ID=tu_chat_id

# ── Trading ──────────────────────────────────────
AUTO_TRADING_ENABLED=false   # true para operar real
TRADE_AMOUNT_USDT=10         # USDT por trade (margen)
LEVERAGE=10                  # Apalancamiento
MAX_OPEN_TRADES=5            # Posiciones simultáneas máx

# ── Estrategia ZigZag++ 15m ──────────────────────
TP_PIPS=45                   # Pips para Take Profit
SL_PIPS=30                   # Pips para Stop Loss
PIVOT_LEN=5                  # Longitud pivot ZigZag
HMA_LEN=50                   # Longitud HMA (filtro)
FT_PERIOD=25                 # Ventana Volume Delta
ATR_LEN=14                   # Longitud ATR
MIN_ATR_PCT=0.08             # ATR % mínimo (filtra inactivos)
VOL_MULT=1.2                 # Multiplicador volumen spike

# ── Escaneo y filtros ─────────────────────────────
SCAN_INTERVAL_SECONDS=60     # Segundos entre ciclos
SCAN_BATCH_SIZE=10           # Pares en paralelo
COOLDOWN_SECONDS=300         # Espera entre señales por par
MIN_VOLUME_USDT=1000000      # Vol 24h mínimo (filtra basura)

# ── Sistema ───────────────────────────────────────
PORT=8080                    # Puerto health check
